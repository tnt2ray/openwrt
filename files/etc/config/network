config interface 'loopback'
	option device 'lo'
	option proto 'static'
	option ipaddr '127.0.0.1'
	option netmask '255.0.0.0'

config globals 'globals'

config device
	option name 'br-lan'
	option type 'bridge'
	list ports 'eth1'
	list ports 'eth2'
	list ports 'eth3'
	list ports 'eth4'
	list ports 'eth5'
	option ipv6 '1'

config interface 'lan'
	option device 'br-lan'
	option proto 'static'
	option ipaddr '192.168.1.1'
	option netmask '255.255.255.0'
	option ip6assign '64'
	option ip6hint '8'

config device
	option name 'eth0'
	option ipv6 '1'

config interface 'WAN'
	option proto 'pppoe'
	option device 'eth0'
	option ipv6 'auto'
	option ip6assign '64'
	option ip6hint '8'

config interface 'WAN6'
	option proto 'dhcpv6'
	option device '@WAN'
	option reqaddress 'try'
	option reqprefix 'auto'
